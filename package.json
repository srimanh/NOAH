{
  "name": "noah-agent",
  "version": "0.1.0",
  "description": "NOAH — Native Operating-system Agentic Harness. Natural language controls your OS, autonomously and safely.",
  "type": "module",
  "bin": {
    "noah": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/sdk.js",
    "./sdk": "./dist/sdk.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "noah": "npm run build && npm run dev",
    "preview": "node dist/ui/preview.js",
    "preview:tui": "node dist/tui/preview.js",
    "test": "node --import tsx --test $(find src -name '*.test.ts')",
    "start": "node dist/cli.js"
  },
  "files": [
    "dist",
    "themes"
  ],
  "keywords": [
    "agent",
    "llm",
    "os",
    "cli",
    "automation",
    "safety"
  ],
  "license": "MIT",
  "dependencies": {
    "@earendil-works/pi-ai": "^0.79.2",
    "@earendil-works/pi-coding-agent": "^0.79.2",
    "@earendil-works/pi-tui": "^0.79.2",
    "typebox": "^1.2.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
